# Server
PORT=3002
NODE_ENV=development
CLIENT_URL=http://localhost:5173
TRUST_PROXY=

# Database
DB_HOST=localhost
DB_PORT=5431
DB_NAME=omnilert_master
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (required, minimum 16 characters each)
JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SUPER_ADMIN_BOOTSTRAP_SECRET=replace-with-very-long-bootstrap-secret-min-32
SUPER_ADMIN_JWT_SECRET=replace-with-very-long-super-admin-jwt-secret-min-32
SUPER_ADMIN_JWT_EXPIRES_IN=1h

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=26214400

# DigitalOcean Spaces (optional)
DO_SPACES_ENDPOINT=https://your-space.region.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=https://your-space.region.cdn.digitaloceanspaces.com
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET_KEY=your-spaces-secret-key
DO_SPACES_BUCKET=your-space-bucket

# Odoo credentials (required)
ODOO_DB=your-odoo-database
ODOO_URL=your-odoo-subdomain.odoo.com
ODOO_USERNAME=admin@example.com
ODOO_PASSWORD=your-odoo-password-or-api-key

# OpenAI (required for CSS audit AI report)
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION_ID=your-openai-organization-id
OPENAI_PROJECT_ID=your-openai-project-id

# SMTP (optional, for registration approval email)
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USER=your-smtp2go-username
SMTP_PASS=your-smtp2go-password
SMTP_FROM=no-reply@example.com
DISCORD_INVITE_URL=https://discord.gg/9E2e4TPS7g
DISCORD_BOT_API_TOKEN=
DISCORD_BOT_CRON_WEBHOOK_URL=
DISCORD_BOT_CRON_WEBHOOK_TOKEN=
DISCORD_BOT_CRON_WEBHOOK_TIMEOUT_MS=5000
SERVICE_CREW_CCTV_CRON_ENABLED=true
SERVICE_CREW_CCTV_CRON_DISABLED_COMPANY_IDS=

# Queue (pg-boss)
QUEUE_SCHEMA=pgboss
EARLY_CHECKIN_QUEUE_NAME=early-checkin-auth
EARLY_CHECKIN_RETRY_LIMIT=3
PEER_EVAL_QUEUE_NAME=peer-evaluation

# CSS audit sampling (optional, 0-1)
CSS_AUDIT_SAMPLE_RATE=0.1

# Permissions probe script (optional)
PERMISSIONS_PROBE_BASE_URL=http://localhost:3001/api

# Web Push (optional, disabled by default)
WEB_PUSH_ENABLED=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:no-reply@example.com
